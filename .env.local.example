# Wavloops landing — environment variables
# Copy this file to .env.local and fill in the values.

# --- Supabase ---
# Dashboard → Settings → API
# https://supabase.com/dashboard/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co

# Public — safe to expose to the browser. Used by the auth client
# (sign-in / sign-up / session refresh).
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGc...your-anon-key

# Server-only — NEVER expose. Used for RLS-bypassing admin operations
# (webhooks, scheduled jobs, contacts insertion). No NEXT_PUBLIC_ prefix.
SUPABASE_SERVICE_ROLE_KEY=eyJhbGc...your-service-role-key

# --- Resend (emails) ---
# Dashboard → API Keys
# https://resend.com/api-keys
RESEND_API_KEY=re_...your-resend-api-key

# Verified sender. For testing without a verified domain, use "onboarding@resend.dev"
# (Resend will only deliver to your own verified inbox in that case).
# Once your domain is verified, use "Wavloops <hello@yourdomain.com>".
RESEND_FROM_EMAIL=Wavloops <onboarding@resend.dev>

# Where admin notifications are sent (every new onboarding submission).
ADMIN_EMAIL=you@yourdomain.com

# --- Cron auth ---
# Random secret (32+ chars) used by /api/cron/* endpoints to gate
# Vercel Cron invocations. Generate with `openssl rand -base64 32`.
# In Vercel Dashboard → Project → Settings → Cron Jobs, set the
# `secret` field to the SAME value.
CRON_SECRET=replace-with-a-long-random-string
